  "STATS_HTML": "\n    <div class=\"stat reveal\">\n      <div class=\"stat-num counter\" data-target=\"1000\" data-suffix=\"+\">1000+</div>\n      <div class=\"stat-label\">Tyytyvaista asiakasta</div>\n    </div>\n\n    <div class=\"stat reveal\">\n      <div class=\"stat-num counter\" data-target=\"9\" data-suffix=\"+\">9+</div>\n      <div class=\"stat-label\">Vuotta kokemusta</div>\n    </div>\n\n    <div class=\"stat reveal\">\n      <div class=\"stat-num counter\" data-target=\"5\" data-suffix=\"/5\">5/5</div>\n      <div class=\"stat-label\">Google-arvosana</div>\n    </div>\n\n    <div class=\"stat reveal\">\n      <div class=\"stat-num counter\" data-target=\"100\" data-suffix=\"%\">100%</div>\n      <div class=\"stat-label\">Suosittelee</div>\n    </div>",
  "SERVICES_HTML": "\n    <div class=\"srv-card reveal\">\n      <div class=\"srv-card-img\"><img src=\"https://images.unsplash.com/photo-1605497788044-5a32c7078486?w=600&h=400&fit=crop&q=80\" alt=\"Leikkaukset\" loading=\"lazy\"></div>\n      <div class=\"srv-card-body\">\n        <div class=\"srv-icon-wrap\"><i data-lucide=\"scissors\"></i></div>\n        <div class=\"srv-name\">Leikkaukset</div>\n        <div class=\"srv-desc\">Ammattitaitoiset leikkaukset naisille, miehille ja lapsille. Neuvomme sinulle sopivan tyylin.</div>\n        <div class=\"srv-price\">25-65 eur</div>\n      </div>\n    </div>\n\n    <div class=\"srv-card reveal\">\n      <div class=\"srv-card-img\"><img src=\"https://images.unsplash.com/photo-1562322140-8baeececf3df?w=600&h=400&fit=crop&q=80\" alt=\"Varjays\" loading=\"lazy\"></div>\n      <div class=\"srv-card-body\">\n        <div class=\"srv-icon-wrap\"><i data-lucide=\"palette\"></i></div>\n        <div class=\"srv-name\">Varjays</div>\n        <div class=\"srv-desc\">Raidat, kokovarjays, balayage ja muut varjaystekniikat. Kaytamme laadukkaita tuotteita.</div>\n        <div class=\"srv-price\">80-180 eur</div>\n      </div>\n    </div>\n\n    <div class=\"srv-card reveal\">\n      <div class=\"srv-card-img\"><img src=\"https://images.unsplash.com/photo-1519699047748-de8e457a634e?w=600&h=400&fit=crop&q=80\" alt=\"Hoidot\" loading=\"lazy\"></div>\n      <div class=\"srv-card-body\">\n        <div class=\"srv-icon-wrap\"><i data-lucide=\"heart\"></i></div>\n        <div class=\"srv-name\">Hoidot</div>\n        <div class=\"srv-desc\">Hiusten syvahoito, keratiinisuoristus ja hiuspohjan hoito. Terveet ja kauniit hiukset.</div>\n        <div class=\"srv-price\">40-120 eur</div>\n      </div>\n    </div>\n\n    <div class=\"srv-card reveal\">\n      <div class=\"srv-card-img\"><img src=\"https://images.unsplash.com/photo-1516975080664-ed2fc6a32937?w=600&h=400&fit=crop&q=80\" alt=\"Kauneuspalvelut\" loading=\"lazy\"></div>\n      <div class=\"srv-card-body\">\n        <div class=\"srv-icon-wrap\"><i data-lucide=\"star\"></i></div>\n        <div class=\"srv-name\">Kauneuspalvelut</div>\n        <div class=\"srv-desc\">Kulmien muotoilu, ripsien kestotaivutus ja muut kauneuspalvelut ammattitaidolla.</div>\n        <div class=\"srv-price\">20-60 eur</div>\n      </div>\n    </div>",
  "REVIEWS_HTML": "\n    <div class=\"rev-card reveal\">\n      <div class=\"rev-stars\"><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg></div>\n      <div class=\"rev-text\">\"Paras kampaamo johon olen kaynyt! Lopputulos oli juuri sellainen kuin toivoin.\"</div>\n      <div class=\"rev-author\">\n        <div class=\"rev-avatar\">S</div>\n        <div class=\"rev-info\"><div class=\"rev-name\">Sanna M.</div><div class=\"rev-role\">Asiakas</div></div>\n      </div>\n    </div>\n\n    <div class=\"rev-card reveal\">\n      <div class=\"rev-stars\"><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg></div>\n      <div class=\"rev-text\">\"Ystavallinen palvelu ja viihtyisa ymparisto. Suosittelen lampimasti!\"</div>\n      <div class=\"rev-author\">\n        <div class=\"rev-avatar\">T</div>\n        <div class=\"rev-info\"><div class=\"rev-name\">Tiina R.</div><div class=\"rev-role\">Asiakas</div></div>\n      </div>\n    </div>\n\n    <div class=\"rev-card reveal\">\n      <div class=\"rev-stars\"><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg></div>\n      <div class=\"rev-text\">\"Taitava kampaaja, joka kuuntelee asiakkaan toiveet. Tulen aina uudelleen.\"</div>\n      <div class=\"rev-author\">\n        <div class=\"rev-avatar\">L</div>\n        <div class=\"rev-info\"><div class=\"rev-name\">Laura P.</div><div class=\"rev-role\">Asiakas</div></div>\n      </div>\n    </div>",
